# ──────────────────────────────────────────────
#  Kundapura Edits Studio — Environment Config
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/kundapura_edits
# For MongoDB Atlas (cloud), use:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/kundapura_edits

# JWT Secret (change this to a long random string in production)
JWT_SECRET=kundapura_edits_super_secret_key_2025
JWT_EXPIRES_IN=7d

# Admin Credentials (used as fallback if DB admin not set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@ke2025

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE_MB=200
UPLOAD_PATH=./backend/uploads





